# Copy to .env or export before starting the server (python server.py).
# Weight precision (default in config.py is int8).
OMNIVOICE_WEIGHT_DTYPE=int8

# Use fp32 full precision instead:
# OMNIVOICE_WEIGHT_DTYPE=fp32

# If int8 fails with the triton backend, try standard PyTorch:
# OMNIVOICE_MODEL_TYPE=standard
