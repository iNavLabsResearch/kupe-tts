# Copy to .env and set your secret (never commit .env)
OMNIVOICE_API_KEY=your-secret-api-key-here

# Optional: comma-separated keys for rotation
# OMNIVOICE_API_KEY=key-one,key-two

# Paths that skip auth (load balancers, docs)
# OMNIVOICE_AUTH_PUBLIC_PATHS=/health,/docs,/openapi.json,/redoc

# WebSocket keepalive (uvicorn ping interval / idle close timeout)
# OMNIVOICE_WS_KEEPALIVE=1
# OMNIVOICE_WS_PING_INTERVAL=20
# OMNIVOICE_IDLE_TIMEOUT=300
# OMNIVOICE_MAX_CONCURRENT=32
